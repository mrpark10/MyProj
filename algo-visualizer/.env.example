# ─────────────────────────────────────────────────────────────
# AlgoVisualizer AI — 환경변수 설정
#
# 사용법: 이 파일을 복사해 `.env` 파일을 만들고 값을 채우세요.
#   copy .env.example .env      (Windows)
#   cp .env.example .env        (macOS/Linux)
#
# 값을 비워두면 앱은 내장된 활용사례 데이터로 정상 동작합니다.
# ─────────────────────────────────────────────────────────────

# LLM 프록시 엔드포인트 URL
VITE_LLM_ENDPOINT=

# 👇 여기에 발급받은 API 키를 붙여넣으세요
VITE_LLM_API_KEY=

# ⚠️ 보안 주의
# VITE_ 접두사 환경변수는 빌드 결과물(JS 번들)에 그대로 포함되어
# 브라우저에서 누구나 볼 수 있습니다. 학습/로컬 실험용으로만 사용하고,
# 실제 배포 시에는 키를 서버에만 두고 프록시 서버를 경유하도록 하세요.
# .env 파일은 .gitignore 에 등록되어 있어 git 에 커밋되지 않습니다.
